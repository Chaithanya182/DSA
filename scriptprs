GIVEN TABLES:
  employees(id, name, department, salary, manager_id)
  departments(id, dept_name, location)

Q: "Get all employees with salary > 50000"
A: SELECT * FROM employees WHERE salary > 50000;

Q: "Get the highest salary in each department"
A: SELECT department, MAX(salary) as max_salary 
   FROM employees 
   GROUP BY department;

Q: "Get employees who earn more than the average salary"
A: SELECT * FROM employees 
   WHERE salary > (SELECT AVG(salary) FROM employees);

Q: "Get the second highest salary"
A: SELECT MAX(salary) FROM employees 
   WHERE salary < (SELECT MAX(salary) FROM employees);
   
   OR (better):
   SELECT salary FROM employees 
   ORDER BY salary DESC LIMIT 1 OFFSET 1;

Q: "Get department names with more than 5 employees"
A: SELECT d.dept_name, COUNT(e.id) as emp_count
   FROM departments d 
   JOIN employees e ON d.id = e.department 
   GROUP BY d.dept_name 
   HAVING COUNT(e.id) > 5;

Q: "Get employees and their manager names"
A: SELECT e.name as employee, m.name as manager
   FROM employees e 
   LEFT JOIN employees m ON e.manager_id = m.id;
   (Self-join — joining a table with itself)

Q: "Delete duplicate rows keeping one"
A: DELETE e1 FROM employees e1
   INNER JOIN employees e2 
   WHERE e1.id > e2.id AND e1.name = e2.name;

EXPLAIN HAVING vs WHERE:
"WHERE filters BEFORE grouping (row-level).
HAVING filters AFTER grouping (group-level).
Example: WHERE salary > 50000 filters individual rows.
HAVING COUNT(*) > 5 filters groups with more than 5 members."


